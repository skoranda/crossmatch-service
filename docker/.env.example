# Docker Compose environment variables for crossmatch-service.
# Copy this file to .env and fill in actual values.
#
#   cp .env.example .env
#
# The .env file is gitignored and will not be committed.

# ----- Build -----
USERID=1000

# ----- Dev environment -----
MAKE_MIGRATIONS=false
DJANGO_DEBUG=true
LOG_LEVEL=DEBUG
DEV_MODE=true

# ----- Django superuser -----
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=password
DJANGO_SUPERUSER_EMAIL=test@example.com

# ----- Database -----
DATABASE_HOST=django-db
DATABASE_PORT=5432
DATABASE_DB=scimma_crossmatch_service
DATABASE_USER=crossmatch_service_admin
DATABASE_PASSWORD=password

# ----- Valkey / Redis -----
VALKEY_SERVICE=redis
VALKEY_PORT=6379

# ----- Application -----
APP_ROOT_DIR=/opt

# ----- ANTARES broker -----
ANTARES_API_KEY=
ANTARES_API_SECRET=
ANTARES_TOPIC=lsst_scimma_quality_transient
ANTARES_GROUP_ID=

# ----- Lasair broker -----
LASAIR_KAFKA_SERVER=lasair-lsst-kafka.lsst.ac.uk:9092
LASAIR_TOPIC=lasair_366SCiMMA_reliability_moderate
LASAIR_GROUP_ID=

# ----- Pitt-Google broker -----
# Requires a GCP service account key file.
# Place at docker/secrets/gcp-pittgoogle-key.json (or set GCP_KEY_FILE path).
GOOGLE_CLOUD_PROJECT=
GCP_KEY_FILE=./secrets/gcp-pittgoogle-key.json
PITTGOOGLE_TOPIC=lsst-alerts-json
PITTGOOGLE_SUBSCRIPTION=scimma-crossmatch-lsst-alerts-json
PITTGOOGLE_PUBLISHER_PROJECT=pitt-alert-broker

# ----- Broker filter standard -----
# Broker-agnostic; see scimma_crossmatch_service_design.md §2.2.
# Minimum reliability score (latest diaSource) admitted to ingest. Must be in [0.0, 1.0].
MIN_DIASOURCE_RELIABILITY=0.6

# ----- Hopskotch publisher -----
# For production Hopskotch:
HOPSKOTCH_BROKER_URL=kafka://kafka.scimma.org
HOPSKOTCH_TOPIC=
HOPSKOTCH_USERNAME=
HOPSKOTCH_PASSWORD=
# For local Kafka testing (docker compose --profile local-kafka up),
# uncomment these and comment out the production values above:
#HOPSKOTCH_BROKER_URL=kafka://local-kafka:9092
#HOPSKOTCH_TOPIC=crossmatch-test

# ----- Celery workers -----
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=4
CELERY_WORKER_LIMIT_CPUS=4.0
CELERY_WORKER_LIMIT_MEMORY=4G

# ----- Dask scheduler -----
# Leave empty for local Dask (default). Set to connect to a remote scheduler.
# When using the dask-scheduler profile (docker compose --profile dask-scheduler up):
#DASK_SCHEDULER_ADDRESS=tcp://dask-scheduler:8786
DASK_SCHEDULER_ADDRESS=
# Max seconds to wait for the cluster to be reachable AND ≥1 worker registered
# before the version-drift check fails. The compose-overridden default (600s)
# absorbs cold pip installs from EXTRA_PIP_PACKAGES on the dask-scheduler/worker
# images. Set lower locally if your image cache is warm.
#DASK_VERSION_CHECK_TIMEOUT_SECONDS=600

# ----- Crossmatch settings -----
CROSSMATCH_BATCH_MAX_WAIT_SECONDS=900
CROSSMATCH_BATCH_MAX_SIZE=100000
GAIA_HATS_URL=s3://stpubdata/gaia/gaia_dr3/public/hats
DES_HATS_URL=s3://stpubdata/mast/public/des/hats/des_y6_gold
DELVE_HATS_URL=s3://stpubdata/mast/public/delve/hats/delve_dr3_gold
SKYMAPPER_HATS_URL=https://data.lsdb.io/hats/skymapper_dr4/catalog
CROSSMATCH_RADIUS_ARCSEC=1.0

# ----- Flower -----
FLOWER_LOG_LEVEL=INFO
FLOWER_URL_PREFIX=
FLOWER_HOST=flower
FLOWER_PORT=8888
